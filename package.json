{
  "name": "pasta",
  "version": "0.1.20",
  "description": "Terminal-first encrypted clipboard relay for trusted desktop devices.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "pasta": "./src/cli.ts"
  },
  "files": [
    "src",
    "scripts",
    "migrations",
    "LICENSE",
    "README.md",
    "GOAL.md",
    "wrangler.jsonc",
    "worker-configuration.d.ts"
  ],
  "scripts": {
    "test": "bun test test/bun && vitest run",
    "test:bun": "bun test test/bun",
    "test:worker": "vitest run",
    "types": "wrangler types",
    "check": "bun run check:no-latest && bun run types && bun test test/bun && vitest run",
    "build:release": "bun scripts/build-release.ts",
    "smoke:macos-image": "bun scripts/smoke-macos-image.ts",
    "pack:list": "bun pm pack --dry-run",
    "check:no-latest": "python3 scripts/check-no-latest.py"
  },
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "qrcode": "1.5.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.20",
    "@types/bun": "1.3.14",
    "@types/qrcode": "1.5.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.105.0"
  },
  "trustedDependencies": []
}
